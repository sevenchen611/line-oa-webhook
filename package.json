{
  "name": "line-oa-webhook",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node scripts/start-server.js",
    "dev": "node --import ./src/control-api.js --watch src/server.js",
    "cron:report": "node scripts/render-cron-report.js",
    "line:groups": "node scripts/sync-line-group-options.js",
    "line:judgements": "node scripts/sync-line-message-judgements.js",
    "judgment:calibration": "node scripts/judgment-calibration.js",
    "meetings:sync": "node scripts/sync-meeting-actions.js",
    "assistant:hourly": "node scripts/sync-line-group-options.js --limit 100 && node scripts/sync-meeting-actions.js --limit 50 && node scripts/sync-line-message-judgements.js --include-outgoing-groups --limit 50 && node scripts/sync-responsibility-candidates.js",
    "responsibility:sync": "node scripts/sync-responsibility-candidates.js",
    "tasks:clean-titles": "node scripts/clean-total-control-task-titles.js",
    "tasks:backfill-details": "node scripts/backfill-active-task-details.js",
    "codex:commands": "node scripts/codex-command-queue.js",
    "line:push": "node scripts/line-push.js",
    "setup:codex-commands": "node scripts/setup-codex-command-queue.js",
    "setup:daily-snapshots": "node scripts/setup-daily-report-snapshots.js",
    "setup:judgment-calibration": "node scripts/judgment-calibration.js create --write-env",
    "setup:responsibility": "node scripts/setup-responsibility-owner-narrowing.js"
  }
}
