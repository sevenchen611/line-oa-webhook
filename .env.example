# Secure control API for proactive LINE push messages.
SEVEN_CONTROL_API_KEY=<SEVEN_CONTROL_API_KEY>

# User UI login for browser-based project/task editing.
SEVEN_USER_UI_USERNAME=<SEVEN_USER_UI_USERNAME>
SEVEN_USER_UI_PASSWORD=<SEVEN_USER_UI_PASSWORD>

# Optional cron tracing / alerting.
CONTROL_LINE_PUSH_URL=https://line-oa-webhook-nn5j.onrender.com/control/line/push
CRON_JOB_NAME=
SEVEN_CRON_ALERTS_ENABLED=true

# Optional fallback target for morning/evening reports.
# If omitted, the service auto-resolves the latest personal Seven conversation from Notion.
SEVEN_REPORT_TARGET_ID=
SEVEN_REPORT_TARGET_TYPE=user
SEVEN_REPORT_TARGET_NAME_KEYWORD=Seven

# Optional public report URLs.
SEVEN_PUBLIC_BASE_URL=https://line-oa-webhook-nn5j.onrender.com
MORNING_BRIEF_URL=
DAILY_REPORT_URL=
FOLLOWUP_CONFIRMATION_URL=

# Optional 08:00 report Google Calendar input.
# Use one of these until the production Google Calendar OAuth connector is wired into SevenAM.
SEVEN_REPORT_TIMEZONE=Asia/Taipei
SEVEN_GOOGLE_CALENDAR_EVENTS_JSON=
SEVEN_GOOGLE_CALENDAR_EVENTS_FILE=
