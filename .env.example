LINE_CHANNEL_ACCESS_TOKEN=put_your_channel_access_token_here
LINE_CHANNEL_SECRET=put_your_channel_secret_here
LINE_CHANNEL_ID=2010309343
PORT=3000

# Notion storage.
NOTION_TOKEN=
SEVEN_CONVERSATIONS_DATA_SOURCE_ID=
SEVEN_MESSAGES_DATA_SOURCE_ID=
SEVEN_ATTACHMENTS_DATA_SOURCE_ID=
SEVEN_ATTACHMENT_CONVERSIONS_DATA_SOURCE_ID=
SEVEN_CODEX_COMMANDS_DATA_SOURCE_ID=

# Secure control API for proactive LINE push messages.
SEVEN_CONTROL_API_KEY=change_this_to_a_long_random_secret

# Optional cron tracing / alerting.
CONTROL_LINE_PUSH_URL=https://line-oa-webhook-nn5j.onrender.com/control/line/push
CRON_JOB_NAME=
SEVEN_CRON_ALERTS_ENABLED=true

# Optional fallback target for morning/evening reports.
# If omitted, the service auto-resolves the latest personal Seven conversation from Notion.
SEVEN_REPORT_TARGET_ID=
SEVEN_REPORT_TARGET_TYPE=user
SEVEN_REPORT_TARGET_NAME_KEYWORD=Seven

# Optional public report URLs.
MORNING_BRIEF_URL=https://htmlpreview.github.io/?https://github.com/sevenchen611/line-oa-webhook/blob/main/reports/morning-brief-prototype.html
DAILY_REPORT_URL=https://htmlpreview.github.io/?https://github.com/sevenchen611/line-oa-webhook/blob/main/reports/daily-control-report-prototype.html
