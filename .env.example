LINE_CHANNEL_ACCESS_TOKEN=<LINE_CHANNEL_ACCESS_TOKEN>
LINE_CHANNEL_SECRET=<LINE_CHANNEL_SECRET>
LINE_CHANNEL_ID=2010309343
PORT=3002

# Notion storage.
NOTION_TOKEN=
SEVEN_CONVERSATIONS_DATA_SOURCE_ID=
SEVEN_MESSAGES_DATA_SOURCE_ID=
SEVEN_ATTACHMENTS_DATA_SOURCE_ID=
SEVEN_ATTACHMENT_CONVERSIONS_DATA_SOURCE_ID=727d16ff-9ef0-47ed-a83d-bbfd3bf4fb1b
SEVEN_CODEX_COMMANDS_DATA_SOURCE_ID=c4eee8de-e596-4d64-906b-1405d79e721c
SEVEN_MEETINGS_DATA_SOURCE_ID=fd551c68-6dac-830d-81bf-879f0a9582ba
SEVEN_TASKS_DATA_SOURCE_ID=0bdc0de5-46ee-482c-b8d7-cdf6ec958467
SEVEN_PROGRESS_REPORTS_DATA_SOURCE_ID=fc5e4e21-6af6-4de2-9380-aa95126ee13e
SEVEN_DAILY_REPORT_SNAPSHOTS_DATA_SOURCE_ID=8f7f95a5-7428-4490-9327-7943499a0e22
SEVEN_RESPONSIBILITY_DATA_SOURCE_ID=e8c2f582-edbe-42ab-9d7f-ba063bbf8b99
